# AWOS Recruitment MCP Server — environment configuration
# Copy this file to .env and adjust values as needed.

# Network interface the server binds to (default: 0.0.0.0)
# AWOS_HOST=0.0.0.0

# TCP port for the Streamable HTTP transport (default: 8000)
# AWOS_PORT=8000

# Version string exposed in MCP server metadata (default: 0.1.0)
# AWOS_VERSION=0.1.0

# Path to the capability registry directory (default: ../registry)
# AWOS_REGISTRY_PATH=../registry

# Maximum number of search results to return (default: 20)
# AWOS_SEARCH_THRESHOLD=20

# PostHog project API key — set to enable usage telemetry (default: unset / disabled)
# AWOS_POSTHOG_API_KEY=phc_your_project_api_key

# PostHog ingestion endpoint (default: https://us.i.posthog.com)
# AWOS_POSTHOG_HOST=https://us.i.posthog.com
